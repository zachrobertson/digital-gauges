{
  "name": "digital-gauges",
  "version": "1.0.3",
  "description": "Desktop app to overlay FIT telemetry (speed, power, HR, cadence, GPS, temperature, etc.) on action-camera video and export a single MP4 with burned-in overlays.",
  "main": "./out/main/index.js",
  "author": "Digital Gauges",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zachrobertson/digital-gauges.git"
  },
  "bugs": {
    "url": "https://github.com/zachrobertson/digital-gauges/issues"
  },
  "homepage": "https://github.com/zachrobertson/digital-gauges#readme",
  "desktopName": "digital-gauges.desktop",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win -p never",
    "build:mac": "electron-vite build && electron-builder --mac -p never",
    "build:linux": "electron-vite build && electron-builder --linux -p never",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "tsx scripts/trim-sync-selftest.ts && tsx scripts/preview-concat-selftest.ts"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/michroma": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@fontsource/oswald": "^5.2.8",
    "@fontsource/rajdhani": "^5.2.7",
    "@fontsource/roboto-condensed": "^5.2.8",
    "@fontsource/saira": "^5.2.11",
    "@fontsource/source-sans-3": "^5.2.9",
    "chokidar": "^4.0.3",
    "esbuild": "^0.28.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fit-file-parser": "~3.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zustand": "^5.0.13"
  },
  "build": {
    "appId": "com.digitalgauges.app",
    "productName": "Digital Gauges",
    "copyright": "Copyright © ${author}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/ffprobe-static/**"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "Digital-Gauges-Setup-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.video",
      "icon": "build/icon.icns",
      "artifactName": "Digital-Gauges-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Video",
      "executableName": "digital-gauges",
      "icon": "build/icons",
      "artifactName": "Digital-Gauges-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.3"
  }
}
